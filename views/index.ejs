<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Mini Chat</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>
    <h3>All Chats</h3>
    <form method="GET" action="/chats/get">
        <button>New Chat</button>
    </form>
    <br>
     <%  for(let chats of data){ %>
        <div class="chatbox">
            <p>From : <%= chats.from %></p>
        <div class="msgbox">
            <p>To : <%= chats.msg %></p>
        </div>
        <p>Received by : <%= chats.to %></p>

        
        <form method="GET" action="/chats/<%= chats._id %>/edit">
            <button>Edit</button>
        </form>


        <br>
        <form method="POST" action="/chats/<%= chats._id %>?_method=DELETE"
            onsubmit="return confirm('Are you sure you want to delete the chat')">
            <button>Delete</button>
        </form>
        <hr/>
      
        </div>
        
   <% } %> 
</body>
</html>